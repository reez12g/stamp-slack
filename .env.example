# Public URL used by Slack callbacks.
# If you run locally, point this to your HTTPS tunnel URL instead of localhost.
APP_BASE_URL=http://localhost:3000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=stamp_slack

# Slack Configuration
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_BOT_SCOPES=commands,chat:write,emoji:read
# Optional. Defaults to SLACK_CLIENT_SECRET when omitted.
SLACK_STATE_SECRET=
# Optional. Defaults to SLACK_CLIENT_SECRET when omitted.
TOKEN_ENCRYPTION_SECRET=
# Optional. Cache TTL in milliseconds for Slack emoji.list results. Defaults to 300000.
EMOJI_CACHE_TTL_MS=300000

# Application Configuration
PORT=3000
NODE_ENV=development
# Optional. Defaults to APP_BASE_URL/?connected=1
AUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/?connected=1
